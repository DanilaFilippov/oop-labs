<Window x:Class="Lab20_Binding.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Lab20_Binding"
        Title="Лабораторная 20 (WPF)" Height="550" Width="500"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <local:ColorToBrushConverter x:Key="ColorToBrushConverter"/>
        <local:StringToFontFamilyConverter x:Key="StringToFontFamilyConverter"/>
    </Window.Resources>
    <StackPanel Margin="10">
        <TextBlock Text="1. Имя (String, TwoWay):" FontWeight="Bold"/>
        <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,10"/>

        <TextBlock Text="2. Активен (Boolean, TwoWay):" FontWeight="Bold"/>
        <CheckBox IsChecked="{Binding IsActive, Mode=TwoWay}" Content="Да" Margin="0,5,0,10"/>

        <TextBlock Text="3. Возраст (Integer, TwoWay):" FontWeight="Bold"/>
        <Slider Minimum="0" Maximum="150" Value="{Binding Age, Mode=TwoWay}" TickFrequency="10" IsSnapToTickEnabled="True" Margin="0,5,0,10"/>
        <TextBlock Text="{Binding Age, StringFormat='Выбрано: {0} лет'}" Margin="0,0,0,10"/>

        <TextBlock Text="4. Рейтинг (Double, TwoWay, FormatString):" FontWeight="Bold"/>
        <TextBox Text="{Binding Score, Mode=TwoWay, StringFormat=F1, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,10"/>

        <TextBlock Text="5. Цвет панели (Color -> Brush, OneWay):" FontWeight="Bold"/>
        <Border Background="{Binding PanelColor, Converter={StaticResource ColorToBrushConverter}}" Width="150" Height="50" BorderBrush="Black" BorderThickness="1" Margin="0,5,0,10"/>
        <Button Content="Изменить цвет в коде" Click="ChangeColor_Click" Margin="0,0,0,10"/>

        <TextBlock Text="6. Шрифт (String -> FontFamily, OneWay):" FontWeight="Bold"/>
        <Label Content="Текст для демонстрации шрифта" FontFamily="{Binding FontName, Converter={StaticResource StringToFontFamilyConverter}, Mode=OneWay}" Margin="0,5,0,10"/>

        <TextBlock Text="7. Динамическая привязка:" FontWeight="Bold"/>
        <TextBlock x:Name="DynamicLabel" Text="(Нажмите кнопку)" Margin="0,5,0,10"/>
        <Button x:Name="DynamicButton" Content="Создать динамическую привязку" Click="CreateDynamicBinding_Click" Width="200" HorizontalAlignment="Left"/>
    </StackPanel>
</Window>